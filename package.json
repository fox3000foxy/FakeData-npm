{
  "name": "fake-data-npm",
  "version": "1.0.6",
  "description": "Library to generate fake profiles and related data",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "publish:npm": "npm publish",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com/fox3000foxy",
    "publish:all": "npm run build && npm run publish:npm && npm run publish:github",
    "format": "bunx --bun @biomejs/biome format --write ./src",
		"check": "bunx --bun @biomejs/biome check ./src",
		"lint": "bunx --bun @biomejs/biome lint ./src",
		"lint:write": "bunx --bun @biomejs/biome lint --write ./src",
		"test": "bunx --bun @biomejs/biome test ./src",
		"build": "tsc --project tsconfig.json"
  },
  "keywords": [
    "fake",
    "data",
    "profiles"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fox3000foxy/FakeData-npm.git"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ]
  }
}
